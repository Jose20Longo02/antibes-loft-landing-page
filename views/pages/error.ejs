<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error | The Villa Above Antibes</title>
  <link rel="stylesheet" href="/css/variables.css">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/components.css">
  <style>
    .error-page { min-height: 80vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem; }
    .error-page h1 { font-family: var(--font-display); font-weight: 300; }
  </style>
</head>
<body>
  <main class="error-page">
    <h1>An error occurred</h1>
    <p><%= message %></p>
    <a href="/" class="btn btn--dark">Return home</a>
  </main>
</body>
</html>
