<% if (typeof metaPixelId !== 'undefined' && metaPixelId) { %>
<script src="<%= assetUrl('/js/meta-pixel.js') %>" data-pixel-id="<%= metaPixelId %>"></script>
<noscript>
  <img
    class="pixel-noscript"
    height="1"
    width="1"
    alt=""
    src="https://www.facebook.com/tr?id=<%= metaPixelId %>&ev=PageView&noscript=1"
  >
</noscript>
<% } %>
