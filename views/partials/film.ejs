<section id="film" class="section section--film" aria-labelledby="film-title">
  <div class="film__spread">
    <div class="film__copy reveal">
      <p class="eyebrow"><%= content.film.label %></p>
      <h2 id="film-title" class="section__title display"><%= content.film.title %></h2>
      <p class="film__lead"><%= content.film.lead %></p>
    </div>

    <figure class="film__figure reveal" data-film>
      <div class="film__frame">
        <img
          class="film__poster"
          src="<%= content.film.poster %>"
          alt=""
          width="720"
          height="1280"
          decoding="async"
          aria-hidden="true"
        >
        <video
          class="film__video"
          playsinline
          muted
          loop
          preload="none"
          poster="<%= content.film.poster %>"
          data-sd="<%= content.film.videoCompressed %>"
          data-hd="<%= content.film.videoHd %>"
          aria-label="<%= content.film.posterAlt %>"
        ></video>
        <div class="film__veil" aria-hidden="true"></div>
        <div class="film__controls">
          <button
            type="button"
            class="film__play"
            data-film-play
            data-pause-label="<%= content.film.pauseLabel %>"
            aria-label="<%= content.film.playLabel %>"
          >
            <span class="film__play-ring" aria-hidden="true"></span>
            <span class="film__play-icon" aria-hidden="true"></span>
          </button>
          <button
            type="button"
            class="film__mute"
            data-film-mute
            data-mute-label="<%= content.film.muteLabel %>"
            hidden
            aria-label="<%= content.film.unmuteLabel %>"
            aria-pressed="true"
          >
            <span class="film__mute-icon film__mute-icon--off" aria-hidden="true"></span>
            <span class="film__mute-icon film__mute-icon--on" aria-hidden="true"></span>
          </button>
        </div>
      </div>
    </figure>

    <aside class="film__aside reveal">
      <div class="film__specs" data-film-specs data-interval="5200">
        <header class="film__specs-head">
          <p class="eyebrow film__specs-eyebrow"><%= content.film.highlightsLabel %></p>
          <p class="film__specs-price display"><%= content.details.price %></p>
          <p class="film__specs-location"><%= content.details.location %></p>
        </header>

        <div class="film__specs-stage" aria-live="polite" aria-atomic="true">
          <p class="film__specs-stage-label" data-spec-stage-label>
            <%= content.film.highlights[0].label %>
          </p>
          <p class="film__specs-stage-value" data-spec-stage-value>
            <%= content.film.highlights[0].value %>
          </p>
        </div>

        <ol class="film__specs-index" role="tablist" aria-label="<%= content.film.highlightsLabel %>">
          <% content.film.highlights.forEach(function (item, i) { %>
            <li class="film__specs-item">
              <button
                type="button"
                class="film__specs-tab<%= i === 0 ? ' is-active' : '' %>"
                role="tab"
                id="film-spec-tab-<%= i %>"
                aria-selected="<%= i === 0 ? 'true' : 'false' %>"
                aria-controls="film-spec-panel"
                data-spec-tab
                data-label="<%= item.label %>"
                data-value="<%= item.value %>"
              >
                <span class="film__specs-tab-num" aria-hidden="true"><%= String(i + 1).padStart(2, '0') %></span>
                <span class="film__specs-tab-label"><%= item.label %></span>
              </button>
            </li>
          <% }); %>
        </ol>

        <div class="film__specs-progress" aria-hidden="true">
          <span class="film__specs-progress-fill" data-spec-progress></span>
        </div>

        <p id="film-spec-panel" class="visually-hidden" role="tabpanel" tabindex="-1"></p>
      </div>
    </aside>
  </div>
</section>
