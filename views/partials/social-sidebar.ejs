<aside class="social-sidebar" aria-label="<%= content.ui.social.label %>">
  <div class="social-sidebar__panel">
    <p class="social-sidebar__eyebrow"><%= content.ui.social.heading %></p>
    <span class="social-sidebar__rule" aria-hidden="true"></span>
    <nav class="social-sidebar__nav">
      <a
        href="<%= config.social.facebook %>"
        class="social-sidebar__link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="<%= content.ui.social.facebook %>"
      >
        <span class="social-sidebar__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" focusable="false">
            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
          </svg>
        </span>
      </a>
      <a
        href="<%= config.social.instagram %>"
        class="social-sidebar__link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="<%= content.ui.social.instagram %>"
      >
        <span class="social-sidebar__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" focusable="false">
            <rect x="3" y="3" width="18" height="18" rx="4"/>
            <circle cx="12" cy="12" r="3.25"/>
            <circle cx="17.2" cy="6.8" r="0.5" fill="currentColor" stroke="none"/>
          </svg>
        </span>
      </a>
      <a
        href="<%= config.social.linkedin %>"
        class="social-sidebar__link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="<%= content.ui.social.linkedin %>"
      >
        <span class="social-sidebar__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" focusable="false">
            <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7H8v-13h4"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </span>
      </a>
      <a
        href="<%= config.social.whatsapp %>"
        class="social-sidebar__link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="<%= content.ui.social.whatsapp %>"
      >
        <span class="social-sidebar__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" focusable="false">
            <path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/>
          </svg>
        </span>
      </a>
    </nav>
  </div>
</aside>
