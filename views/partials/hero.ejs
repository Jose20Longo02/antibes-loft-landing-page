<section id="hero" class="hero" aria-label="Introduction">
  <div class="hero__media">
    <%- include('picture-img', {
      className: 'hero__image',
      src: content.hero.image,
      webp: content.hero.imageWebp,
      src960: content.hero.image960,
      webp960: content.hero.image960Webp,
      alt: content.hero.alt,
      width: 1400,
      height: 933,
      fetchpriority: 'high',
      sizes: '100vw',
    }) %>
    <div class="hero__veil" aria-hidden="true"></div>
  </div>
  <div class="hero__content reveal">
    <div class="hero__head">
      <p class="eyebrow"><%= content.hero.eyebrow %></p>
      <h1 class="hero__title display">
        <span class="hero__title-line"><%= content.hero.headlineLine1 %></span>
        <span class="hero__title-line"><%= content.hero.headlineLine2 %></span>
      </h1>
    </div>

    <div class="hero__summary" aria-label="Property summary">
      <p class="hero__summary-type"><%= content.hero.offer %></p>
      <p class="hero__summary-price">
        <span class="hero__summary-amount"><%= content.hero.price %></span>
        <span class="hero__summary-note"><%= content.hero.priceNote %></span>
      </p>
    </div>

    <div class="hero__actions">
      <a href="#presentation" class="btn btn--light"><%= content.hero.cta %></a>
    </div>
  </div>
  <a href="#idea" class="hero__scroll" aria-label="<%= content.ui.discover %>">
    <span class="hero__scroll-text"><%= content.ui.discover %></span>
    <span class="hero__scroll-line" aria-hidden="true"></span>
  </a>
</section>
