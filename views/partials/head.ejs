<% const pageCanonical = typeof canonicalUrl !== 'undefined' ? canonicalUrl : homeUrl; %>
<% const shareImage = typeof ogImage !== 'undefined' ? ogImage : ''; %>
<% const ogLocales = { en: 'en_GB', fr: 'fr_FR', de: 'de_DE' }; %>
<% const ogLocale = ogLocales[lang] || 'en_GB'; %>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="<%= typeof meta !== 'undefined' ? meta.description : '' %>">
<meta name="theme-color" content="#f7f5f1">
<title><%= typeof title !== 'undefined' ? title : '' %></title>
<%- include('meta-pixel') %>
<% if (typeof localeSwitcher !== 'undefined') { %>
  <% localeSwitcher.forEach(function (loc) { %>
    <link rel="alternate" hreflang="<%= loc.code %>" href="<%= loc.href %>">
  <% }); %>
  <link rel="alternate" hreflang="x-default" href="<%= typeof siteUrl !== 'undefined' && siteUrl ? siteUrl + '/en' : '/en' %>">
<% } %>
<link rel="canonical" href="<%= pageCanonical %>">
<meta property="og:type" content="website">
<meta property="og:site_name" content="<%= config.siteName %>">
<meta property="og:title" content="<%= typeof title !== 'undefined' ? title : '' %>">
<meta property="og:description" content="<%= typeof meta !== 'undefined' ? meta.description : '' %>">
<meta property="og:url" content="<%= pageCanonical %>">
<meta property="og:locale" content="<%= ogLocale %>">
<% if (shareImage) { %>
<meta property="og:image" content="<%= shareImage %>">
<meta property="og:image:alt" content="<%= content.hero.alt %>">
<% } %>
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : '' %>">
<meta name="twitter:description" content="<%= typeof meta !== 'undefined' ? meta.description : '' %>">
<% if (shareImage) { %>
<meta name="twitter:image" content="<%= shareImage %>">
<% } %>
<% if (typeof preloadHero !== 'undefined' && preloadHero && content.hero && content.hero.imageWebp) { %>
<link
  rel="preload"
  as="image"
  type="image/webp"
  imagesrcset="<%= content.hero.image960Webp %> 960w, <%= content.hero.imageWebp %> 1400w"
  imagesizes="100vw"
>
<% } %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;450;500&display=swap" rel="stylesheet">
<link rel="icon" href="<%= assetUrl(config.logo) %>" type="image/png">
<link rel="stylesheet" href="<%= assetUrl('/css/variables.css') %>">
<link rel="stylesheet" href="<%= assetUrl('/css/base.css') %>">
<link rel="stylesheet" href="<%= assetUrl('/css/typography.css') %>">
<link rel="stylesheet" href="<%= assetUrl('/css/layout.css') %>">
<link rel="stylesheet" href="<%= assetUrl('/css/components.css') %>">
<link rel="stylesheet" href="<%= assetUrl('/css/sections.css') %>">
<link rel="stylesheet" href="<%= assetUrl('/css/gallery.css') %>">
<link rel="stylesheet" href="<%= assetUrl('/css/social-sidebar.css') %>">
