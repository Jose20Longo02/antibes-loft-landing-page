<%#
  locals:
    src, webp, src960, webp960, alt,
    className, width, height, loading, fetchpriority, sizes
%>
<% const hasSrcset = typeof webp960 !== 'undefined' && webp960 && typeof src960 !== 'undefined' && src960 && typeof webp !== 'undefined' && webp; %>
<% const hasWebp = typeof webp !== 'undefined' && webp; %>
<picture>
  <% if (hasSrcset) { %>
    <source
      type="image/webp"
      srcset="<%= webp960 %> 960w, <%= webp %> 1400w"
      sizes="<%= typeof sizes !== 'undefined' ? sizes : '100vw' %>"
    >
    <source
      type="image/jpeg"
      srcset="<%= src960 %> 960w, <%= src %> 1400w"
      sizes="<%= typeof sizes !== 'undefined' ? sizes : '100vw' %>"
    >
  <% } else if (hasWebp) { %>
    <source type="image/webp" srcset="<%= webp %>">
  <% } %>
  <img
    <% if (typeof className !== 'undefined' && className) { %>class="<%= className %>"<% } %>
    src="<%= src %>"
    alt="<%= alt %>"
    <% if (typeof width !== 'undefined' && width) { %>width="<%= width %>" height="<%= height %>"<% } %>
    <% if (typeof loading !== 'undefined' && loading) { %>loading="<%= loading %>"<% } %>
    <% if (typeof fetchpriority !== 'undefined' && fetchpriority) { %>fetchpriority="<%= fetchpriority %>"<% } %>
    decoding="async"
  >
</picture>
