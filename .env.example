# Server
NODE_ENV=production
PORT=3000
# Public URL (required in production) — no trailing slash
# On Render, RENDER_EXTERNAL_URL is used automatically if SITE_URL is unset
SITE_URL=https://your-domain.com
# Set to number of proxies in front of the app (Railway/Render/Heroku: 1)
TRUST_PROXY=1

# Privacy page linked from the inquiry form
PRIVACY_POLICY_URL=https://www.finlaybrewer.com/privacy-policy

# Google Sheets — see docs/GOOGLE-SHEETS.md
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Gmail — lead notification emails
# 1. Use a Google account with 2-Step Verification enabled
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Use that 16-character password as SMTP_PASS (not your normal Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.name@gmail.com
SMTP_PASS=your-google-app-password
EMAIL_FROM="Finlay Brewer International" <your.name@gmail.com>
NOTIFICATION_EMAIL=your-inbox@example.com

# Meta Pixel — optional; leave empty to disable
META_PIXEL_ID=

# Meta Conversions API — server-side Lead events (recommended for reliable tracking)
# Events Manager → your pixel → Settings → Conversions API → Generate access token
META_CONVERSIONS_API_ACCESS_TOKEN=
